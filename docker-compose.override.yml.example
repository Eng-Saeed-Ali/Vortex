version: '3.9'

services:
  postgres:
    ports:
      - "5432:5432"
    command: postgres -c log_statement=all -c log_destination=stderr

  redis:
    ports:
      - "6379:6379"

  elasticsearch:
    ports:
      - "9200:9200"
      - "9300:9300"

  api:
    build:
      context: .
      dockerfile: Dockerfile.api
    environment:
      - NODE_ENV=development
      - LOG_LEVEL=debug
      - DEBUG=*
    volumes:
      - ./src:/app/src
      - ./package.json:/app/package.json
      - ./tsconfig.json:/app/tsconfig.json
      - ./nest-cli.json:/app/nest-cli.json
      - /app/dist
    command: npm run start:dev
    ports:
      - "3000:3000"
      - "9229:9229"  # Debug port
    # Development overrides - relaxed security
    # Run as root to avoid EACCES permission issues with rmdir /app/dist
    user: "0"
    read_only: false
    cap_drop: []
    cap_add: []
    security_opt: []

  scraper:
    build:
      context: .
      dockerfile: Dockerfile.scraper
    environment:
      - NODE_ENV=development
      - LOG_LEVEL=debug
      - DEBUG=pw:api
    volumes:
      - ./src:/app/src
      - ./package.json:/app/package.json
      - ./tsconfig.json:/app/tsconfig.json
      - scraper_downloads:/home/pwuser/downloads
    ports:
      - "9230:9230"  # Debug port
    # Development overrides - relaxed security for debugging
    user: "pwuser"
    read_only: false
    cap_drop: []
    cap_add: []
    security_opt: []
    command: npm run start:dev

volumes:
  scraper_downloads: