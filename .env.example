# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vortex?schema=public
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=vortex
DATABASE_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Redis BullMQ (separate connection for queues)
REDIS_QUEUE_HOST=localhost
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_PASSWORD=
REDIS_QUEUE_DB=1

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# API Security
API_RATE_LIMIT_TTL=60000
API_RATE_LIMIT_LIMIT=100
API_THROTTLE_TTL=60000
API_THROTTLE_LIMIT=10
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here-change-in-production
ENCRYPTION_IV=your-16-char-iv-here

# Swagger / OpenAPI
SWAGGER_TITLE=Vortex Pipeline API
SWAGGER_DESCRIPTION=Vortex Data Pipeline API Documentation
SWAGGER_VERSION=1.0
SWAGGER_PATH=api/docs

# Health Checks
HEALTH_CHECK_INTERVAL=30000

# Scheduler
SCHEDULER_TIMEZONE=UTC
CRON_TIMEZONE=UTC

# Webhooks
WEBHOOK_SECRET=your-webhook-secret-change-in-production
WEBHOOK_TIMEOUT=5000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000

# Scraper Service
SCRAPER_SERVICE_URL=http://localhost:9230
SCRAPER_TIMEOUT=30000
SCRAPER_CONCURRENCY=3
SCRAPER_HEADLESS=true
SCRAPER_USER_AGENT=VortexBot/1.0 (+https://vortex.example.com/bot)
SCRAPER_DOWNLOAD_DIR=/home/pwuser/downloads
SCRAPER_CACHE_DIR=/home/pwuser/.cache

# Playwright
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Elasticsearch (for logging)
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=vortex-logs

# Monitoring / Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Feature Flags
FEATURE_DEDUPLICATION_ENABLED=true
FEATURE_ENRICHMENT_ENABLED=true
FEATURE_WEBHOOKS_ENABLED=true
FEATURE_AUDIT_LOGGING=true

# Rate Limiting (Redis-based)
RATE_LIMITER_REDIS_HOST=localhost
RATE_LIMITER_REDIS_PORT=6379
RATE_LIMITER_REDIS_PASSWORD=
RATE_LIMITER_POINTS=100
RATE_LIMITER_DURATION=60

# Deduplication
DEDUP_THRESHOLD=0.85
DEDUP_ALGORITHM=cosine

# Validation
VALIDATION_STRICT_MODE=true
VALIDATION_PHONE_DEFAULT_COUNTRY=US

# Enrichment
ENRICHMENT_API_KEY=
ENRICHMENT_API_URL=https://api.enrichment-service.com